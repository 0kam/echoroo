# ============================================
# Echoroo Rebuild Configuration
# ============================================
# Copy this file to .env and modify the values
# cp .env.example .env
#
# Required variables are marked with (REQUIRED)

# ============================================
# PostgreSQL Database (REQUIRED)
# ============================================
POSTGRES_DB=echoroo
POSTGRES_USER=postgres
# (REQUIRED - change this!)
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_USE
# Database port (exposed to host for dev tools)
POSTGRES_PORT=5432

# ============================================
# Redis
# ============================================
REDIS_PORT=6379

# ============================================
# Audio Directory
# ============================================
# Path on the HOST where audio files are stored
# This directory will be mounted read-only in containers
ECHOROO_AUDIO_DIR=/path/to/your/audio/files

# ============================================
# LocalStack Data Directory
# ============================================
# Host path for LocalStack S3 persistence (bind mount)
# Defaults to ./.data/localstack if not set
# ECHOROO_LOCALSTACK_DATA=./.data/localstack

# ============================================
# Network Configuration
# ============================================
# Browser-facing host (bare hostname or IP — NO scheme, NO port).
# This single variable is the ONLY thing you need to set for a LAN-IP or
# remote-host deployment: every browser-facing URL (frontend, API, S3
# proxy), the CORS allowlist, and the WebAuthn relying-party config derive
# from it. Ports keep their own knobs (ECHOROO_FRONTEND_PORT /
# ECHOROO_API_PORT). The scheme stays http in this dev stack — put a
# reverse proxy in front for TLS in production.
#
# Examples:
#   ECHOROO_PUBLIC_HOST=localhost          # default — laptop / SSH port-forward
#   ECHOROO_PUBLIC_HOST=192.168.1.100      # GPU box / LAN access by IP
#   ECHOROO_PUBLIC_HOST=echoroo.example.org # FQDN
#
# DUAL-ORIGIN NOTE: setting a non-localhost host does NOT remove localhost
# from the CORS / WebAuthn allowlists — both the public-host origin AND the
# localhost origin stay enabled simultaneously, so users who reach the app
# via SSH port-forward (arriving as localhost) keep working alongside LAN
# clients. Leaving it at localhost is byte-identical to the previous setup.
ECHOROO_PUBLIC_HOST=localhost

# Backend API port (exposed to host)
ECHOROO_API_PORT=8002

# Frontend port (exposed to host)
ECHOROO_FRONTEND_PORT=5173

# ============================================
# Security
# ============================================
# JWT secret key (REQUIRED for production - change this!)
JWT_SECRET_KEY=dev-secret-key-change-in-production

# ============================================
# Invitation token signing (required at every boot)
# ============================================
# kid + HMAC key pair for the 4-part invitation token envelope
# (per spec/011 NFR-011-010, mirrors Phase 17 A-12 `_NEW`/`_OLD` rotation).
#
# On every boot:
#   - INVITATION_TOKEN_KID_NEW + INVITATION_TOKEN_HMAC_KEY are REQUIRED.
#   - Generate a key with: openssl rand -hex 32
#
# On INITIAL deploy of spec/011 (and during any planned rotation):
#   - INVITATION_TOKEN_KID_OLD + INVITATION_TOKEN_HMAC_KEY_OLD MUST be set
#     to the legacy values so 3-part legacy tokens in flight remain
#     verifiable during the grace window. The app refuses to start if
#     KID_OLD is set without HMAC_KEY_OLD (and vice versa).
#
# After the grace window expires (= invitation TTL 7d + GRACE_HOURS),
# both _OLD vars MAY be unset.
INVITATION_TOKEN_KID_NEW=spec011-v1
INVITATION_TOKEN_HMAC_KEY=
INVITATION_TOKEN_KID_OLD=
INVITATION_TOKEN_HMAC_KEY_OLD=
INVITATION_TOKEN_KID_GRACE_HOURS=24

# ============================================
# ML / inference (worker)
# ============================================
# Device + OOM-safety knobs for the Celery ML worker (BirdNET + Perch, both
# on TensorFlow). Defaults preserve the historical GPU behaviour, so a host
# with a working GPU needs none of these set.
#
# If your GPU is present but unusable by TensorFlow (e.g. NVIDIA Blackwell /
# RTX 50-series / sm_120), set ECHOROO_ML_USE_GPU=false and
# ECHOROO_WORKER_MEM_LIMIT=24g (tune to ~40% of host RAM). CPU mode
# auto-caps inference threads (ECHOROO_ML_CPU_NUM_THREADS) and shrinks the
# Perch warmup (ECHOROO_ML_CPU_WARMUP_BATCHES) to avoid OOM that can reboot
# the host.
#
# NOTE: ECHOROO_ML_USE_GPU=false alone is enough only when an NVIDIA GPU is
# PRESENT (just unusable by TF). On a host with NO NVIDIA GPU at all you must
# ALSO remove/comment the worker's deploy.resources.reservations.devices
# block in compose.dev.yaml, or the worker container will fail to start.
ECHOROO_ML_USE_GPU=true
ECHOROO_ML_GPU_BATCH_SIZE=16
ECHOROO_ML_FEEDERS=1
ECHOROO_ML_WORKERS=1
ECHOROO_ML_CPU_NUM_THREADS=8
ECHOROO_ML_CPU_WARMUP_BATCHES=1
ECHOROO_ML_GPU_ALLOW_GROWTH=true
# Compose-level RAM cap for the worker container(s). 0 = unlimited (current
# GPU behaviour). On a CPU/Blackwell box set e.g. 24g to keep the host alive.
ECHOROO_WORKER_MEM_LIMIT=0

# ============================================
# External APIs
# ============================================
# Xeno-canto API key — required for the "From Xeno-canto" search/import feature
# in the project search screen. Without it the Xeno-canto entry points are
# disabled in the UI and the search endpoint returns a 409
# (xeno_canto_not_configured) rather than failing at the upstream API.
# Register a free account at https://xeno-canto.org/ then copy the key from
# your account page (Account -> API key). Leave blank (or "demo") to disable.
XENO_CANTO_API_KEY=

# ============================================
# Boot probes (fail-fast on missing infrastructure)
# ============================================
# At startup the API (FastAPI lifespan) and Celery workers ping Redis and run
# an S3 head_bucket so a misconfigured deployment crashes loudly instead of at
# first use. Redis failure is fatal in every environment; S3 failure is fatal
# only in staging/production (logged + tolerated in development). Set to 1 to
# skip all probes (offline tooling / tests).
ECHOROO_SKIP_BOOT_CHECKS=0

# ============================================
# Security fail-closed switches (W4-2)
# ============================================
# Legacy Bearer/JWT token-revocation check (services/auth.py). When true
# (default) a Redis outage makes the revocation check fail CLOSED (HTTP 503)
# so a revoked token can never be silently accepted and a logout that could
# not persist its revocation marker cannot report success. Set to false ONLY
# as a dev escape hatch to restore the historical fail-open behaviour;
# refused when ENVIRONMENT=production.
ECHOROO_AUTH_REVOCATION_FAIL_CLOSED=true
# HaveIBeenPwned (HIBP) breach check during password enforcement
# (register / change-password / invitation accept). When false (default) an
# HIBP outage fails CLOSED (HTTP 503, "verification service unavailable")
# instead of silently accepting a possibly-breached password. Set true (or
# enable TEST_MODE) to restore fail-open for dev / offline use; refused when
# ENVIRONMENT=production.
ECHOROO_HIBP_FAIL_OPEN=false

# ============================================
# Quick Start
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Set POSTGRES_PASSWORD to a secure password
# 3. Set ECHOROO_AUDIO_DIR to your audio directory
# 4. Start: ./echoroo.sh start
#
# Development:
#   ./echoroo.sh start    # Start
#   ./echoroo.sh logs     # View logs
#   ./echoroo.sh db       # Connect to database
#   ./echoroo.sh stop     # Stop

# ============================================
# ----- 006 permissions redesign: KMS envelope encryption -----
# ============================================
# LocalStack backs KMS in dev; point these at real AWS KMS CMKs in prod.
# The alias DEFAULTS match scripts/init-localstack.sh, so the dev stack works
# with these commented out. The compose file passes AWS_ENDPOINT_URL_KMS /
# AWS_KMS_REGION to the containers already — the lines below document the full
# set for non-compose runs and production.
#
# Endpoint: AWS_KMS_ENDPOINT and AWS_ENDPOINT_URL_KMS are interchangeable.
# AWS_KMS_ENDPOINT=http://localstack:4566
# AWS_KMS_REGION=us-east-1                            # falls back to AWS_DEFAULT_REGION
# AWS_KMS_CMK_2FA_ALIAS=alias/echoroo-totp-dek        # TOTP DEK envelope encryption (FR-051)
# AWS_KMS_CMK_PII_HASH_ALIAS=alias/echoroo-pii-hash-hmac       # PII hashing via GenerateMac (FR-091b, v1)
# AWS_KMS_CMK_AUDIT_CHAIN_ALIAS=alias/echoroo-audit-chain-hmac # audit log chain HMAC (FR-093)
# AWS_KMS_CMK_INVITATION_HMAC_ALIAS=alias/echoroo-invitation-hmac  # invitation token HMAC (FR-040, legacy single-key)
#
# --- PII-hash CMK rotation (FR-091b dual-write; set only during rotation) ---
# AWS_KMS_CMK_PII_HASH_ALIAS_V2=alias/echoroo-pii-hash-hmac-v2
# ECHOROO_PII_HASH_ROTATION_COMPLETE=                 # rotation phase flag consumed by core/kms.py
#
# --- Invitation-signing CMK rotation (set _OLD only during the grace window) ---
# AWS_KMS_CMK_INVITATION_HMAC_ALIAS_NEW=alias/echoroo-invitation-hmac
# AWS_KMS_CMK_INVITATION_HMAC_ALIAS_OLD=
#
# --- TOTP DEK CMK rotation (Settings-backed, Phase 17 A-8; see docs/runbook/dek_rewrap.md) ---
# _OLD alias + _OLD kid MUST be set together (or both unset).
# AWS_KMS_CMK_2FA_DEK_ALIAS_NEW=alias/echoroo-totp-dek
# AWS_KMS_CMK_2FA_DEK_KID_NEW=1
# AWS_KMS_CMK_2FA_DEK_ALIAS_OLD=
# AWS_KMS_CMK_2FA_DEK_KID_OLD=

# ============================================
# Redis (dev builds a rediss:// TLS URL from the vars below in compose)
# ============================================
# For non-compose runs, set REDIS_URL directly. Production must use rediss://
# with ssl_cert_reqs=required.
# REDIS_URL=redis://localhost:6379/0
# REDIS_USERNAME=echoroo
# REDIS_PASSWORD=echoroo-dev-redis-password

# ============================================
# WebAuthn (superuser hardware-key 2FA, FR-111a)
# ============================================
# NOTE: the env names are ECHOROO_-prefixed. Bare WEBAUTHN_RP_ID / WEBAUTHN_ORIGIN
# are NOT read by the code. All three default from ECHOROO_PUBLIC_HOST when unset.
# ECHOROO_WEBAUTHN_RP_ID=localhost               # Relying Party ID; must match the browser hostname (e.g. echoroo.app in prod)
# ECHOROO_WEBAUTHN_RP_NAME=Echoroo               # Relying Party display name shown on authenticators
# ECHOROO_WEBAUTHN_ORIGINS=http://localhost:3000 # Comma-separated allowed WebAuthn origins

# ============================================
# First-party web session / BFF secret (spec/009, spec/011)
# ============================================
# NOTE: lowercase env name (no alias; case_sensitive). REQUIRED and must be a
# strong >=32-char secret in production/staging. Not set by compose.
# Generate with: openssl rand -hex 32
# web_session_secret=dev-web-session-secret-change-in-production

# ============================================
# 2FA reset-confirmation HMAC (Phase 17 A-12)
# ============================================
# REQUIRED as a strong >=32-char secret in production/staging (dev has a default).
# See docs/runbook/two_factor_confirmation_key_rotation.md for rotation.
# TWO_FACTOR_RESET_CONFIRMATION_HMAC_KEY=
# TWO_FACTOR_RESET_CONFIRMATION_HMAC_KID_NEW=v1
# TWO_FACTOR_RESET_CONFIRMATION_HMAC_KEY_OLD=
# TWO_FACTOR_RESET_CONFIRMATION_HMAC_KID_OLD=

# ============================================
# External integrations & observability (all optional)
# ============================================
# IUCN Red List threat-status sync (worker/script). Unset skips the sync.
# IUCN_API_TOKEN=
# IUCN_API_BASE_URL=https://apiv3.iucnredlist.org/api/v3
# Sentry telemetry. Unset/empty disables Sentry (spec/011 default).
# SENTRY_DSN=
# SENTRY_RELEASE=

# ============================================
# TEST_MODE 2FA shared-secret bypass (Playwright / preview only)
# ============================================
# NEVER set in production — startup refuses TEST_MODE=true when ENVIRONMENT=production.
# TEST_MODE=true
# TEST_TOTP_SECRET_BASE32=JBSWY3DPEHPK3PXP
