# ============================================
# Echoroo API - Development Image
# FastAPI with hot reload via uvicorn
# ============================================
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Place the virtual environment outside /app so it is not shadowed
# by the bind-mount (./apps/api:/app) used by worker / beat services.
ENV UV_PROJECT_ENVIRONMENT=/opt/venv

# Copy dependency files
COPY pyproject.toml uv.lock ./

# Install dependencies
RUN uv sync --frozen --no-dev --no-install-project

# Copy source code
COPY . .

# Install the project itself
RUN uv sync --frozen --no-install-project

# Create a non-root user (uid=1000) matching the typical host user.
# This prevents root-owned files from appearing on bind-mounted host
# directories (e.g. celerybeat-schedule, __pycache__).
RUN groupadd -g 1000 appuser \
    && useradd -u 1000 -g appuser -m appuser

# Create data directories and set ownership
RUN mkdir -p /data/audio /data/cache /home/appuser/.local/share/birdnet \
    && chown -R appuser:appuser /data /opt/venv /home/appuser

USER appuser

EXPOSE 8000

# Run with hot reload for development
CMD ["uv", "run", "uvicorn", "echoroo.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "/app/echoroo"]
