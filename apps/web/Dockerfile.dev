# ============================================
# Echoroo Frontend - Development Image
# SvelteKit with Vite hot reload
# ============================================
FROM node:22-alpine

WORKDIR /app

# Copy dependency files
COPY package.json package-lock.json ./

# Install all dependencies (including devDependencies)
RUN npm ci

# Copy source files
COPY . .

# Ensure the built-in 'node' user (uid=1000) owns /app so
# npm / Vite / Paraglide can write caches and generated files
# without creating root-owned files on bind-mounted host volumes.
RUN chown -R node:node /app

USER node

EXPOSE 5173

# Run SvelteKit dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
