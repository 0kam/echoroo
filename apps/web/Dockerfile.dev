# ============================================
# Echoroo Frontend - Development Image
# SvelteKit with Vite hot reload
# ============================================
FROM node:22-alpine

WORKDIR /app

# Copy dependency files
COPY package.json package-lock.json ./

# Install all dependencies (including devDependencies)
RUN npm ci

# Copy source files
COPY . .

# Ensure the built-in 'node' user (uid=1000) owns /app so
# npm / Vite / Paraglide can write caches and generated files
# without creating root-owned files on bind-mounted host volumes.
# Pre-create /app/src/lib/paraglide before chown: a fresh named volume
# mounted there inherits node ownership from this image path, letting
# Vite's paraglide plugin generate the runtime without a manual chown.
RUN mkdir -p /app/src/lib/paraglide && chown -R node:node /app

USER node

EXPOSE 5173

# Run SvelteKit dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
