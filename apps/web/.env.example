# API Configuration
# In Docker, ECHOROO_API_URL is set by compose (e.g., http://backend:8000)
# For local development outside Docker, point to the backend port
ECHOROO_API_URL=http://localhost:8002

# Public environment variables (exposed to client)
# This is used by the API client for server-side rendering
PUBLIC_API_URL=http://localhost:8002
