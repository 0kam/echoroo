# Dependencies
node_modules

# Build outputs
.svelte-kit
build
dist

# Paraglide-JS generated code (auto-generated, do not commit).
# Ignore contents but keep the directory tracked via .gitkeep: a named
# volume mounts at /app/src/lib/paraglide under the :ro src bind mount,
# so the host dir must exist on a fresh clone for docker to mount it.
src/lib/paraglide/*
!src/lib/paraglide/.gitkeep
src/paraglide/

# Environment variables
.env
.env.*
!.env.example

# Testing
coverage
playwright-report
test-results

# Editor
.vscode/*
!.vscode/extensions.json
.idea
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
